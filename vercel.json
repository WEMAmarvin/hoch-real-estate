{
  "rewrites": [
    {
      "source": "/api/immobilien",
      "destination": "/api/immobilien.js"
    },
    {
      "source": "/api/expose",
      "destination": "/api/expose.js"
    },
    {
      "source": "/api/expose-v2",
      "destination": "/api/expose-v2.js"
    },
    {
      "source": "/api/expose-v3",
      "destination": "/api/expose-v3.js"
    },
    {
      "source": "/api/expose-html",
      "destination": "/api/expose-html.js"
    },
    {
      "source": "/api/expose-html-v4",
      "destination": "/api/expose-html-v4.js"
    },
    {
      "source": "/api/expose-html-v5",
      "destination": "/api/expose-html-v5.js"
    },
    {
      "source": "/api/template-check",
      "destination": "/api/template-check.js"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}